# ============================================================
# ProManage 環境変数テンプレート
#   このファイルをコピーして .env.local を作成し、各値を埋めてください。
#   .env.local は Git にコミットしない（公開しない）こと。
#   Vercel では「Project Settings → Environment Variables」に同じキーを登録します。
# ============================================================

# ── Supabase（プロジェクトの Settings → API から取得）──
# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# anon public キー（クライアント公開用）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...（anon キー）
# service_role キー（サーバー専用・絶対に公開しない。招待APIで使用）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...（service_role キー）

# ── サイトURL（招待メールのリンク先・流入経路の誘導URLなどに使用）──
# ローカル: http://localhost:3000 / 本番: https://あなたのドメイン
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── 運営ゾーン（/ops）の IP 許可リスト（Phase 2：入り口分離）──
#   カンマ区切りの IPv4/IPv6。空（未設定）なら IP 制限しない＝段階導入できる。
#   例: OPS_ALLOWED_IPS=203.0.113.24,198.51.100.7
#   ⚠️ リモートワークがある場合は設定しない（自分を締め出す）。
#      Vercel Pro 以上なら Vercel Firewall のほうが手前で弾けるので推奨。
OPS_ALLOWED_IPS=

# ── ChatWork 通知（スケジュール通知を使う場合）──
# ChatWork の API トークン（サーバー専用・公開しない）
CHATWORK_API_TOKEN=（ChatWork APIトークン）
# 定時実行エンドポイント（/api/cron/notify）を保護するための任意のシークレット
CRON_SECRET=（ランダムな長い文字列）

# ── AI機能（Anthropic Claude）──────────────────────────────
#   ① メンバーAI相談 / ② 返信提案 / ③ 添削 / ④ HTML生成 / ⑤ 配信原稿生成
#   すべてサーバー側（API Route）からのみ呼び出す。クライアントに出さない。
# APIキー（https://console.anthropic.com で発行）
ANTHROPIC_API_KEY=sk-ant-...
# 既定モデル（①②④⑤で使用）
ANTHROPIC_MODEL=claude-sonnet-4-5
# 軽量モデル（③添削など短文タスク。未設定なら ANTHROPIC_MODEL を使う）
ANTHROPIC_MODEL_LIGHT=claude-3-5-haiku-latest

# ── AI レート制限・コスト上限（任意。未設定なら括弧内が既定値）──
# メンバー1人あたりの1分あたり呼び出し上限（10）
AI_RATE_LIMIT_PER_MIN=10
# 1機能あたりの1日上限（50）
AI_RATE_LIMIT_PER_DAY=50
# ① メンバーAI相談の1日上限（10）
AI_CONSULT_DAILY_LIMIT=10
# ②③④⑤（スタッフ向け）の1日上限（200）
AI_OPS_DAILY_LIMIT=200
# プロンプトへ投入するチャット履歴の最大件数（40）
AI_MAX_CONTEXT_MESSAGES=40
